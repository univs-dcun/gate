// UG-237: 파이프라인 로직은 univs-dcun/gate-jenkins-library 레포(main 브랜치)에서 단일 관리한다.
// 로직 수정은 library 레포에서, 이 파일은 서비스 식별 파라미터만 갖는다.
@Library('gate-jenkins-library') _

univsServicePipeline(
    serviceName:   'gate-service',
    serviceNameKo: '유니버스 게이트 서비스',
    envVarName:    'GATE_SERVICE_VERSION',
    servicePath:   'backend/gate',
    // UG-238 검증 게이트 파일럿 (관측 모드 — 빌드를 실패시키지 않음)
    gates: [
        risk:     true,       // L0: 변경 파일 기반 위험 등급 판별
        contract: 'observe',  // L1b: API 계약 검사 (breaking 감지 시 Slack 경고만)
        mutation: 'observe',  // L1c: 뮤테이션 테스트 (킬률 70% 미만 시 Slack 경고만)
    ]
)

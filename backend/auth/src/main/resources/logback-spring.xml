<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} [%X{traceId},%X{spanId}] - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/auth.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- maxFileSize 를 넘어섰을 때 원본 파일명 + 날짜 + 인덱스 이름으로 파일 분리 -->
            <fileNamePattern>logs/auth-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- 1개 파일의 최대 크기 -->
            <maxFileSize>10MB</maxFileSize>
            <!-- 보관할 로그 파일의 최대 수, 초과된 파일은 자동으로 삭제 -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>[auth-server] %d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} [%X{traceId},%X{spanId}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- openapi: API 계약 스펙 생성용 프로파일 (UG-241) — 부팅 로그를 콘솔로 확인 가능해야 한다 -->
    <springProfile name="local,openapi">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
    </springProfile>

    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
        </root>
    </springProfile>

    <springProfile name="stag">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
        </root>
    </springProfile>

    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
        </root>
    </springProfile>
</configuration>
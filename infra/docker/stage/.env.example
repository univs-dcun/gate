# ================================================================
# 스테이징 서버(192.168.0.136) .env 예시(example) (UG-235)
# 실제 파일 위치: /home/univs/platform/docker/config/.env
#
# ⚠️ <SECRET> 표시 값은 git에 저장하지 않는다. 실제 값은 서버의 .env에만 존재.
# ⚠️ *_VERSION 값은 Jenkins 배포가 sed로 갱신하는 살아있는 값 —
#    아래는 스냅샷(2026-07-08) 시점 예시이며 서버의 현재 값과 다를 수 있다.
# ================================================================

# Dockhub URL
DOCKHUB_GATE_URL=dockhub.univs.ai:9870/univs-gate
DOCKHUB_POINT_URL=dockhub.univs.ai:9870/univs-point

# Database - Postgresql or Oracle
CORE_DB_URL=jdbc:postgresql://platform-postgresql
CORE_DB_USERNAME=postgres
CORE_DB_PASSWORD=<SECRET>

# Cash Store - Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<SECRET>

# Frontend dockhub image version
GATE_WEB_VERSION=1.0.11
DEMO_WEB_VERSION=1.0.8

# Backend dockhub image version
DISCOVERY_SERVER_VERSION=20260616-8cae733
CONFIG_SERVER_VERSION=20260708-35d8196
GATEWAY_SERVER_VERSION=20260629-4c76103
AUTH_SERVICE_VERSION=20260706-05e63cf
FACE_SERVICE_VERSION=20260706-9d5e02b
MATCH_SERVER_VERSION=20260706-10927ca
FXP_PREPROCESS_SERVICE_VERSION=1.0.7-vi
GATE_SERVICE_VERSION=20260706-c3c1d34
NOTIFY_SERVICE_VERSION=20260312-69baff3
PALM_SERVICE_VERSION=20260706-e9f8cbf

## Backend env
# Option for starting Spring framework
SPRING_PROFILES_ACTIVE=stag
CORE_SPRING_PROFILES_ACTIVE=stag, postgresql

# Config server profile git or native(file in the local server)
CONFIG_SERVER_PROFILE=git, stag
GIT_USERNAME=univs-dcun
GIT_PASSWORD=<SECRET: GitHub PAT (repo scope) — gate-config 레포 접근용>

# Management port
MANAGEMENT_SERVER_PORT=9001

# File
FILE_API_ENDPOINT_GET=/api/v1/file
FILE_ENABLE_UPLOAD=true
FILE_ROOT_PATH=/var/uploads
FILE_SECRET_KEY=<SECRET>
FILE_ALGORITHM_WAY=AES
FILE_ALGORITHM_MOD=AES/ECB/PKCS5Padding

# JWT secret key
JWT_SECRET=<SECRET>
JWT_CREATE_USER_TOKEN_EXPIRY=300000
JWT_ACCESS_TOKEN_EXPIRY=900000
JWT_REFRESH_TOKEN_EXPIRY=604800000

# GMAIL
GOOGLE_OAUTH2_EMAIL=univs_platform@univs.ai
GOOGLE_OAUTH2_CLIENT_ID=52756227842-ud91vtp6d8319mnp30oukrhdfaed74pa.apps.googleusercontent.com
GOOGLE_OAUTH2_CLIENT_SECRET=<SECRET>
GOOGLE_OAUTH2_REFRESH_TOKEN=<SECRET>
GOOGLE_OAUTH2_ACCESS_TOKEN_URL=https://www.googleapis.com/oauth2/v4/token

# URL
WEB_SOCKET_ALLOW_ORIGINS=https://socket-stage.univsgate.com
PALM_MODULE_URL=https://palm.univsgate.com
GATEWAY_URL=https://api-stage.univsgate.com
GATE_DEMO_URL=https://demo-stage.univsgate.com

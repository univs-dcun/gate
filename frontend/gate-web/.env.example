# API
VITE_API_BASE_URL=http://localhost:8080/api

# App
VITE_APP_NAME=UnivsAiGateService
VITE_APP_VERSION=1.0.0

# SDK 모드 QR URL 파싱/교체 (서버와 동일 호스트 환경에서만 true로 설정)
# true: 서버 반환 link를 파싱하여 로컬 테스트 URL로 교체
# false(기본): 서버 반환 link 그대로 사용
VITE_QR_URL_REWRITE=false

# API 개발 가이드 링크 (개발 지원 페이지에서 사용)
VITE_API_GUIDE_URL=
